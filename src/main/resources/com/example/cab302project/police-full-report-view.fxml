<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.cab302project.PoliceFullReportController"
            prefHeight="400.0" prefWidth="600.0">

    <children>

        <VBox spacing="10" layoutX="20" layoutY="20">

            <Label text="Full Crime Report" />

            <Label fx:id="descriptionLabel" text="Description"/>
            <Label fx:id="priorityLabel" text="Priority"/>
            <Label fx:id="timeLabel" text="Time"/>

            <Pane prefHeight="200" prefWidth="300"
                  style="-fx-border-color: black;">
                <Label text="Map View (placeholder)"
                       layoutX="50" layoutY="80"/>
            </Pane>

            <Button text="Back" onAction="#onBack"/>

        </VBox>

    </children>

</AnchorPane>
