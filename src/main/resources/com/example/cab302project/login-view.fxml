<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!-- Login screen - light card design with RADIUS app bar -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.cab302project.LoginController"
           styleClass="auth-root"
           stylesheets="@styles.css">

    <VBox spacing="0" StackPane.alignment="TOP_CENTER">

        <!-- App bar -->
        <HBox styleClass="app-bar" alignment="CENTER">
            <Label text="RADIUS" styleClass="app-bar-title"/>
        </HBox>

        <!-- Tab bar -->
        <HBox styleClass="tab-bar" alignment="CENTER">
            <Button text="Log In"
                    styleClass="tab-btn, tab-btn-active"
                    onAction="#onTabLogin"
                    maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <Button text="Sign Up"
                    styleClass="tab-btn"
                    onAction="#onTabSignup"
                    maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Scrollable card area -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;"
                    VBox.vgrow="ALWAYS">

            <VBox alignment="TOP_CENTER">
                <padding><Insets top="32" right="24" bottom="32" left="24"/></padding>

                <VBox styleClass="auth-card" maxWidth="380" spacing="20">

                    <VBox spacing="4">
                        <Label text="Sign in to your Account" styleClass="auth-title"/>
                        <Label text="Enter your credentials to continue" styleClass="auth-subtitle"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Username" styleClass="auth-label"/>
                        <!-- fx:id and onAction preserved from original -->
                        <TextField fx:id="usernameField"
                                   promptText="Enter your username"
                                   styleClass="auth-field"
                                   onAction="#onLogin"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Password" styleClass="auth-label"/>
                        <!-- fx:id and onAction preserved from original -->
                        <PasswordField fx:id="passwordField"
                                       promptText="Enter your password"
                                       styleClass="auth-field"
                                       onAction="#onLogin"/>
                    </VBox>

                    <!-- onLogin preserved from original -->
                    <Button text="Log In"
                            onAction="#onLogin"
                            maxWidth="Infinity"
                            styleClass="btn-primary"/>

                    <HBox alignment="CENTER" spacing="4">
                        <Label text="Don't have an account?" styleClass="link-muted"/>
                        <!-- onRegister preserved from original -->
                        <Label text="Sign Up"
                               styleClass="link-text"
                               onMouseClicked="#onRegister"/>
                    </HBox>

                </VBox>
            </VBox>
        </ScrollPane>

    </VBox>

</StackPane>