<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_LEFT" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.cab302project.CrimesController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Crime Report Database" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <HBox VBox.vgrow="ALWAYS" spacing="20.0">
        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <TableView fx:id="crimeTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="50" />
                    <TableColumn fx:id="categoryColumn" text="Category" prefWidth="120" />

                    <TableColumn fx:id="severityColumn" text="Severity" prefWidth="100" />

                    <TableColumn fx:id="timestampColumn" text="Date/Time" prefWidth="150" />

                    <TableColumn fx:id="actionedColumn" text="Actioned" prefWidth="80" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
            <Button text="Back to Dashboard" onAction="#onBackButtonClick" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="10.0" prefWidth="350">
            <Label text="Report Details" style="-fx-font-weight: bold;" />
            <GridPane hgap="10.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="80" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="Crime ID #:" GridPane.rowIndex="0" />
                <Label fx:id="idLabel" text="-" style="-fx-font-weight: bold; -fx-text-fill: #555;"
                       GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Category:" GridPane.rowIndex="1" />
                <ComboBox fx:id="categoryComboBox" maxWidth="Infinity"
                          GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Severity:" GridPane.rowIndex="2" />
                <Label fx:id="severityLabel" text="-" style="-fx-font-weight: bold;"
                       GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Date:" GridPane.rowIndex="3" />
                <DatePicker fx:id="datePicker" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Time:" GridPane.rowIndex="4" />
                <HBox spacing="5" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="4">
                    <ComboBox fx:id="hourBox" prefWidth="70" />
                    <ComboBox fx:id="minuteBox" prefWidth="70" />
                    <ComboBox fx:id="ampmBox" prefWidth="70" />
                </HBox>

                <Label text="Location:" GridPane.rowIndex="5" />
                <TextField fx:id="locationField" promptText="lat, lon"
                           GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <Label text="Description:" GridPane.rowIndex="6" />
                <TextArea fx:id="descriptionArea" wrapText="true" prefHeight="200"
                          GridPane.columnIndex="1" GridPane.rowIndex="6" />

                <Label text="Reporter:" GridPane.rowIndex="7" />
                <TextField fx:id="reporterField" editable="false" style="-fx-background-color: #f4f4f4;"
                           GridPane.columnIndex="1" GridPane.rowIndex="7" />

                <Label text="Status:" GridPane.rowIndex="8" />
                <CheckBox fx:id="actionedCheckBox" text="Crime Actioned"
                          GridPane.columnIndex="1" GridPane.rowIndex="8" />

            </GridPane>

            <VBox spacing="10.0" prefWidth="350">
                <Button text="Delete Selected Report" onAction="#onDeleteCrime" maxWidth="Infinity" />

                <Button text="Create New Report" onAction="#onAddNewCrime" maxWidth="Infinity" />

                <Button text="Save Changes" onAction="#onSave" maxWidth="Infinity" />
            </VBox>

        </VBox>
    </HBox>
</VBox>