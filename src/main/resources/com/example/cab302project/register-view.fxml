<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!-- Register screen - light card design with RADIUS app bar -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.cab302project.RegisterController"
           styleClass="auth-root"
           stylesheets="@styles.css">

    <VBox spacing="0" StackPane.alignment="TOP_CENTER">

        <!-- App bar -->
        <HBox styleClass="app-bar" alignment="CENTER">
            <Label text="RADIUS" styleClass="app-bar-title"/>
        </HBox>

        <!-- Tab bar -->
        <HBox styleClass="tab-bar" alignment="CENTER">
            <Button text="Log In"
                    styleClass="tab-btn"
                    onAction="#onTabLogin"
                    maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <Button text="Sign Up"
                    styleClass="tab-btn, tab-btn-active"
                    onAction="#onTabSignup"
                    maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Scrollable card area -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;"
                    VBox.vgrow="ALWAYS">

            <VBox alignment="TOP_CENTER">
                <padding><Insets top="32" right="24" bottom="32" left="24"/></padding>

                <VBox styleClass="auth-card" maxWidth="380" spacing="18">

                    <VBox spacing="4">
                        <Label text="Get Started" styleClass="auth-title"/>
                        <Label text="Create an account to get started" styleClass="auth-subtitle"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Username" styleClass="auth-label"/>
                        <!-- fx:id and onAction preserved from original -->
                        <TextField fx:id="usernameField"
                                   promptText="Choose a username"
                                   styleClass="auth-field"
                                   onAction="#onRegisterAccount"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Email" styleClass="auth-label"/>
                        <!-- fx:id and onAction preserved from original -->
                        <TextField fx:id="emailField"
                                   promptText="example@gmail.com"
                                   styleClass="auth-field"
                                   onAction="#onRegisterAccount"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Password" styleClass="auth-label"/>
                        <!-- fx:id and onAction preserved from original -->
                        <PasswordField fx:id="passwordField"
                                       promptText="Choose a password"
                                       styleClass="auth-field"
                                       onAction="#onRegisterAccount"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Phone" styleClass="auth-label"/>
                        <!-- fx:id and onAction preserved from original -->
                        <TextField fx:id="phoneField"
                                   promptText="10-digit mobile number"
                                   styleClass="auth-field"
                                   onAction="#onRegisterAccount"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Home Location" styleClass="auth-label"/>
                        <TextField fx:id="locationField"
                                   promptText="Search for your home address"
                                   styleClass="auth-field"
                                   onAction="#onRegisterAccount"/>
                    </VBox>

                    <!-- onRegisterAccount preserved from original -->
                    <Button text="Create Account"
                            onAction="#onRegisterAccount"
                            maxWidth="Infinity"
                            styleClass="btn-primary"/>

                    <HBox alignment="CENTER" spacing="4">
                        <Label text="Already have an account?" styleClass="link-muted"/>
                        <!-- onReturnToLogin preserved from original -->
                        <Label text="Log In"
                               styleClass="link-text"
                               onMouseClicked="#onReturnToLogin"/>
                    </HBox>

                </VBox>
            </VBox>
        </ScrollPane>

    </VBox>

</StackPane>