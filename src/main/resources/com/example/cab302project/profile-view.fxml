<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.cab302project.ProfileController"
           fx:id="profileRoot"
           stylesheets="@styles.css">

    <VBox alignment="TOP_LEFT" spacing="0">

        <!-- App bar -->
        <HBox styleClass="app-bar" alignment="CENTER_LEFT" spacing="0">
            <Button fx:id="hamburgerBtn" text="☰" styleClass="hamburger-btn"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="RADIUS" styleClass="app-bar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Region minWidth="40"/>
        </HBox>

        <!-- Form content - centred, no scroll -->
        <VBox alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
            <padding><Insets top="32" right="24" bottom="24" left="24"/></padding>

            <VBox styleClass="auth-card" maxWidth="380" spacing="16">

                <!-- Heading -->
                <VBox spacing="4">
                    <Label text="My Profile" styleClass="auth-title"/>
                    <Label fx:id="usernameLabel" styleClass="auth-subtitle"/>
                </VBox>

                <!-- New Password -->
                <VBox spacing="6">
                    <Label text="New Password" styleClass="auth-label"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Leave blank to keep current"
                                   styleClass="auth-field"
                                   onAction="#onSave"/>
                </VBox>

                <!-- Email -->
                <VBox spacing="6">
                    <Label text="Email" styleClass="auth-label"/>
                    <TextField fx:id="emailField"
                               styleClass="auth-field"
                               onAction="#onSave"/>
                </VBox>

                <!-- Phone -->
                <VBox spacing="6">
                    <Label text="Phone" styleClass="auth-label"/>
                    <TextField fx:id="phoneField"
                               styleClass="auth-field"
                               onAction="#onSave"/>
                </VBox>

                <!-- Home Location -->
                <VBox spacing="6">
                    <Label text="Home Location" styleClass="auth-label"/>
                    <TextField fx:id="locationField"
                               promptText="latitude, longitude"
                               styleClass="auth-field"
                               onAction="#onSave"/>
                </VBox>

                <!-- Settings -->
                <VBox spacing="6">
                    <Label text="Settings" styleClass="auth-label"/>
                    <CheckBox fx:id="darkModeCheckBox" text="Enable Dark Mode"
                              style="-fx-font-size: 13px; -fx-text-fill: #374151;"/>
                </VBox>

                <!-- Save button inline in card -->
                <Button text="SAVE CHANGES"
                        onAction="#onSave"
                        maxWidth="Infinity"
                        styleClass="btn-primary"/>

            </VBox>
        </VBox>

        <!-- Bottom navigation bar -->
        <fx:include fx:id="navBar" source="nav-bar.fxml"/>

    </VBox>

    <!-- HamburgerMenu overlay -->

</StackPane>
