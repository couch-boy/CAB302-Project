<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.web.WebView?>

<!-- Root is StackPane so HamburgerMenu can overlay on top of all content -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.cab302project.DashboardController"
           fx:id="dashboardRoot"
           stylesheets="@styles.css">

    <!-- Page content -->
    <VBox alignment="TOP_LEFT" spacing="0">

        <!-- App bar with hamburger button and RADIUS title -->
        <HBox styleClass="app-bar" alignment="CENTER_LEFT" spacing="0">
            <Button fx:id="hamburgerBtn" text="☰" styleClass="hamburger-btn"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="RADIUS" styleClass="app-bar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Spacer to balance hamburger button and keep title centred -->
            <Region minWidth="40"/>
        </HBox>

        <!-- Main content below app bar -->
        <VBox spacing="12" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="16" left="20" right="20" top="16"/></padding>

            <Label fx:id="welcomeLabel" text="Loading user details..."/>
            <Label fx:id="emailLabel" text="Loading user details..."/>
            <Button text="Logout" onAction="#onLogout"/>
            <Button text="View Crimes" onAction="#viewCrimes"/>
            <Button text="View Hotspots" onAction="#viewHotspots"/>
            <Button text="View Profile" onAction="#viewProfile"/>
            <WebView fx:id="mapView" VBox.vgrow="ALWAYS"/>

        </VBox>

    </VBox>

    <!-- HamburgerMenu is added programmatically in DashboardController.initialize() -->

</StackPane>