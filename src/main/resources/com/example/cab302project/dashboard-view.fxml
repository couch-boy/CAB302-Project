<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.web.WebView?>

<!-- Root is StackPane so HamburgerMenu can overlay on top of all content -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.cab302project.DashboardController"
           fx:id="dashboardRoot"
           stylesheets="@styles.css">

    <!-- Page content -->
    <VBox alignment="TOP_LEFT" spacing="0">

        <!-- App bar with hamburger button and RADIUS title -->
        <HBox styleClass="app-bar" alignment="CENTER_LEFT" spacing="0">
            <Button fx:id="hamburgerBtn" text="☰" styleClass="hamburger-btn"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="RADIUS" styleClass="app-bar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Spacer to balance hamburger button and keep title centred -->
            <Region minWidth="40"/>
        </HBox>

        <!-- Hotspots map fills remaining height -->
        <WebView fx:id="mapView" VBox.vgrow="ALWAYS"/>

        <!-- Submit Report pinned to bottom -->
        <VBox style="-fx-background-color: #FFFFFF;
                     -fx-border-color: #E5E7EB;
                     -fx-border-width: 1 0 0 0;
                     -fx-padding: 12 20 12 20;">
            <Button text="SUBMIT REPORT"
                    onAction="#onSubmitReport"
                    maxWidth="Infinity"
                    styleClass="btn-primary"
                    style="-fx-padding: 14 0 14 0;"/>
        </VBox>

    </VBox>

    <!-- HamburgerMenu is added programmatically in DashboardController.initialize() -->

</StackPane>