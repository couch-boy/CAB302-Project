<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.web.WebView?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!-- Root is StackPane so HamburgerMenu can overlay on top of all content -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.cab302project.DashboardController"
           fx:id="dashboardRoot"
           stylesheets="@styles.css">

    <!-- Page content -->
    <VBox alignment="TOP_LEFT" spacing="0">

        <!-- App bar with hamburger button and RADIUS title -->
        <HBox styleClass="app-bar" alignment="CENTER_LEFT" spacing="0">
            <Button fx:id="hamburgerBtn" styleClass="hamburger-btn">
                <graphic><FontIcon iconLiteral="fas-bars" iconSize="18" iconColor="#2A364E"/></graphic>
            </Button>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="RADIUS" styleClass="app-bar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Spacer to balance hamburger button and keep title centred -->
            <Region minWidth="40"/>
        </HBox>

        <!-- Search bar and category filter -->
        <VBox styleClass="search-panel" spacing="6">
            <padding><Insets top="10" right="12" bottom="8" left="12"/></padding>

            <!-- Suburb search row -->
            <HBox spacing="6" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="Search suburb or area..."
                           styleClass="search-field"
                           onAction="#onSearch"
                           HBox.hgrow="ALWAYS"/>
                <Button text="Search"
                        onAction="#onSearch"
                        styleClass="btn-primary"
                        style="-fx-padding: 8 14 8 14;"/>
                <Button text="Clear"
                        onAction="#onClearSearch"
                        styleClass="btn-secondary"
                        style="-fx-padding: 8 14 8 14;"/>
            </HBox>

            <!-- Category filter row -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Filter:" styleClass="filter-label"/>
                <ComboBox fx:id="categoryFilter"
                          onAction="#onCategoryChanged"
                          styleClass="filter-combo"
                          maxWidth="Infinity"
                          HBox.hgrow="ALWAYS"/>
                <Label fx:id="searchStatusLabel"
                       styleClass="search-status"
                       maxWidth="Infinity"
                       HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <!-- Hotspots map fills remaining height -->
        <WebView fx:id="mapView"
                 prefWidth="1920"
                 prefHeight="1920"
                 VBox.vgrow="ALWAYS"
                 HBox.hgrow="ALWAYS" />

        <!-- Hotspot intensity legend -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #FFFFFF; -fx-padding: 8 20 8 20;
                     -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0;">
            <Label text="●" style="-fx-text-fill: #DC143C; -fx-font-size: 11px;"/>
            <Label text="High Activity" style="-fx-text-fill: #6B7280; -fx-font-size: 11px;"/>
            <Label text="●" style="-fx-text-fill: #FF8C00; -fx-font-size: 11px;"/>
            <Label text="Moderate Activity" style="-fx-text-fill: #6B7280; -fx-font-size: 11px;"/>
            <Label text="●" style="-fx-text-fill: #FFD700; -fx-font-size: 11px;"/>
            <Label text="Low Activity" style="-fx-text-fill: #6B7280; -fx-font-size: 11px;"/>
        </HBox>

        <!-- Submit Report pinned to bottom -->
        <VBox style="-fx-background-color: #FFFFFF;
                     -fx-border-color: #E5E7EB;
                     -fx-border-width: 1 0 0 0;
                     -fx-padding: 12 20 12 20;">
            <Button text="SUBMIT REPORT"
                    onAction="#onSubmitReport"
                    maxWidth="Infinity"
                    styleClass="btn-primary"
                    style="-fx-padding: 14 0 14 0;"/>
        </VBox>

        <!-- Bottom navigation bar -->
        <fx:include fx:id="navBar" source="nav-bar.fxml"/>

    </VBox>

    <!-- HamburgerMenu is added programmatically in DashboardController.initialize() -->

</StackPane>