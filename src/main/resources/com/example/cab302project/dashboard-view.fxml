<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.web.WebView?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!-- Root is StackPane so HamburgerMenu and the floating search bar
     can overlay on top of map content -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.cab302project.DashboardController"
           fx:id="dashboardRoot"
           stylesheets="@styles.css">

    <!-- Base layer: full-height map + fixed bars at top and bottom -->
    <VBox alignment="TOP_LEFT" spacing="0">

        <!-- App bar -->
        <HBox styleClass="app-bar" alignment="CENTER_LEFT" spacing="0">
            <Button fx:id="hamburgerBtn" styleClass="hamburger-btn">
                <graphic><FontIcon iconLiteral="fas-bars" iconSize="18" iconColor="#2A364E"/></graphic>
            </Button>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="RADIUS" styleClass="app-bar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Region minWidth="40"/>
        </HBox>

        <!-- Map fills ALL remaining space — search bar floats over it -->
        <WebView fx:id="mapView"
                 prefWidth="1920"
                 prefHeight="1920"
                 VBox.vgrow="ALWAYS"
                 HBox.hgrow="ALWAYS"/>

        <!-- Hotspot intensity legend -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #FFFFFF; -fx-padding: 8 20 8 20;
                     -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0;">
            <Label text="●" style="-fx-text-fill: #DC143C; -fx-font-size: 11px;"/>
            <Label text="High Activity" style="-fx-text-fill: #6B7280; -fx-font-size: 11px;"/>
            <Label text="●" style="-fx-text-fill: #FF8C00; -fx-font-size: 11px;"/>
            <Label text="Moderate Activity" style="-fx-text-fill: #6B7280; -fx-font-size: 11px;"/>
            <Label text="●" style="-fx-text-fill: #FFD700; -fx-font-size: 11px;"/>
            <Label text="Low Activity" style="-fx-text-fill: #6B7280; -fx-font-size: 11px;"/>
        </HBox>

        <!-- Submit Report -->
        <VBox style="-fx-background-color: #FFFFFF;
                     -fx-border-color: #E5E7EB;
                     -fx-border-width: 1 0 0 0;
                     -fx-padding: 12 20 12 20;">
            <Button text="SUBMIT REPORT"
                    onAction="#onSubmitReport"
                    maxWidth="Infinity"
                    styleClass="btn-primary"
                    style="-fx-padding: 14 0 14 0;"/>
        </VBox>

        <!-- Bottom navigation bar -->
        <fx:include fx:id="navBar" source="nav-bar.fxml"/>

    </VBox>

    <!-- Floating search bar overlay — pinned to top-right, 360px wide.
         StackPane.margin top=60 clears the 52px app bar. -->
    <VBox fx:id="searchOverlay"
          styleClass="search-overlay"
          StackPane.alignment="TOP_RIGHT"
          maxHeight="-Infinity"
          maxWidth="360"
          pickOnBounds="false">
        <StackPane.margin>
            <Insets top="60" right="12"/>
        </StackPane.margin>

        <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>

        <!-- Search row: field + Search + Clear + Filter icon -->
        <HBox spacing="6" alignment="CENTER_LEFT">
            <TextField fx:id="searchField"
                       promptText="Search suburb or area..."
                       styleClass="search-field-float"
                       onAction="#onSearch"
                       HBox.hgrow="ALWAYS"/>
            <Button text="Search"
                    onAction="#onSearch"
                    styleClass="search-btn-float"/>
            <Button text="✕"
                    onAction="#onClearSearch"
                    styleClass="icon-btn-float"
                    fx:id="clearBtn"/>
            <!-- Filter toggle button — shows/hides the filter drawer -->
            <Button fx:id="filterToggleBtn"
                    onAction="#onToggleFilter"
                    styleClass="icon-btn-float">
                <graphic><FontIcon iconLiteral="fas-sliders-h" iconSize="14" iconColor="#2A364E"/></graphic>
            </Button>
        </HBox>

        <!-- Status label shown below search bar when suburb or filter is active -->
        <Label fx:id="searchStatusLabel"
               styleClass="search-status-float"
               maxWidth="Infinity"/>

    </VBox>

    <!-- Full-width filter drawer — overlays the entire map when open.
         Sits as its own StackPane child so it is not constrained by the
         360px search overlay. Clicking the transparent backdrop closes it. -->
    <StackPane fx:id="filterBackdrop"
               managed="false"
               visible="false"
               onMouseClicked="#onBackdropClicked"
               StackPane.alignment="TOP_CENTER">
        <StackPane.margin>
            <!-- top=115 clears the 60px app-bar offset + ~50px search bar row -->
            <Insets top="115" left="12" right="12"/>
        </StackPane.margin>

        <!-- Semi-transparent backdrop covers the map and catches outside clicks -->
        <Pane style="-fx-background-color: rgba(0,0,0,0.01);"
              mouseTransparent="false"/>

        <!-- Filter card aligned to top, inset 12px each side leaving map edges visible -->
        <VBox fx:id="filterDrawer"
              styleClass="filter-drawer"
              spacing="10"
              StackPane.alignment="TOP_CENTER"
              maxHeight="-Infinity"
              onMouseClicked="#onFilterDrawerClicked">
            <padding><Insets top="12" right="16" bottom="16" left="16"/></padding>

            <HBox alignment="CENTER_RIGHT">
                <Label text="Filter crimes" styleClass="filter-drawer-title" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="✕"
                        onAction="#onToggleFilter"
                        styleClass="icon-btn-float"
                        style="-fx-font-size: 11px; -fx-padding: 4 8 4 8;"/>
            </HBox>

            <!-- Crime type -->
            <VBox spacing="4">
                <Label text="Crime type" styleClass="filter-drawer-label"/>
                <ComboBox fx:id="categoryFilter"
                          onAction="#onCategoryChanged"
                          styleClass="filter-drawer-combo"
                          maxWidth="Infinity"/>
            </VBox>

            <!-- Time range -->
            <VBox spacing="4">
                <Label text="Time range" styleClass="filter-drawer-label"/>
                <ComboBox fx:id="daysFilter"
                          onAction="#onDaysChanged"
                          styleClass="filter-drawer-combo"
                          maxWidth="Infinity"/>
            </VBox>

            <!-- Actioned status -->
            <VBox spacing="4">
                <Label text="Status" styleClass="filter-drawer-label"/>
                <ComboBox fx:id="actionedFilter"
                          onAction="#onActionedChanged"
                          styleClass="filter-drawer-combo"
                          maxWidth="Infinity"/>
            </VBox>

            <!-- Reset filters -->
            <Button text="Reset all filters"
                    onAction="#onResetFilters"
                    maxWidth="Infinity"
                    styleClass="btn-secondary"
                    style="-fx-padding: 10 0 10 0;"/>

        </VBox>
    </StackPane>

    <!-- HamburgerMenu added programmatically in DashboardController.initialize() -->

</StackPane>