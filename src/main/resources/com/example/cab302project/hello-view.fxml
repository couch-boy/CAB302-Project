<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!-- Landing screen - dark branded entry point -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.cab302project.HelloController"
           styleClass="landing-root"
           stylesheets="@styles.css">

  <!-- Radial glow from top to match Figma design -->
  <Pane mouseTransparent="true"
        style="-fx-background-color: radial-gradient(center 50% 0%, radius 60%, rgba(255,255,255,0.13) 0%, transparent 100%);"/>

  <!-- Main content -->
  <VBox alignment="CENTER" spacing="0" StackPane.alignment="CENTER">

    <!-- Logo block -->
    <VBox alignment="CENTER" spacing="10">
      <Label text="◉"
             style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 52px;
                          -fx-effect: dropshadow(gaussian, rgba(255,255,255,0.15), 40, 0.4, 0, 0);"/>
      <!-- fx:id="welcomeText" kept for controller binding -->
      <Label fx:id="welcomeText" text="RADIUS" styleClass="landing-logo"/>
      <Label text="Community Crime Reporting" styleClass="landing-tagline"/>
    </VBox>

    <Region prefHeight="80"/>

    <!-- CTA buttons -->
    <VBox spacing="14" maxWidth="300">
      <!-- loginButton kept for controller binding - navigates to login -->
      <Button fx:id="loginButton"
              text="Sign In"
              onAction="#onLoginButtonClick"
              maxWidth="Infinity"
              styleClass="btn-landing-primary"/>

      <!-- onHelloButtonClick navigates to register -->
      <Button text="Create an Account"
              onAction="#onHelloButtonClick"
              maxWidth="Infinity"
              styleClass="btn-landing-secondary"/>
    </VBox>

    <Label text="Stay informed. Stay safe."
           styleClass="landing-tagline"
           style="-fx-padding: 28 0 0 0; -fx-font-size: 10px;"/>
  </VBox>

</StackPane>