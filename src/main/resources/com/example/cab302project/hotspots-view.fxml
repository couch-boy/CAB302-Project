<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<VBox alignment="TOP_LEFT" spacing="0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.cab302project.HotspotsController">

    <Button text="Back to Dashboard"
            onAction="#onBackButtonClick"
            style="-fx-padding: 10 16 10 16;">
        <VBox.margin>
            <Insets top="12" left="12" bottom="4" right="12"/>
        </VBox.margin>
    </Button>

    <WebView fx:id="mapView"
             prefWidth="1920"
             prefHeight="1920"
             VBox.vgrow="ALWAYS"/>

    <fx:include fx:id="navBar" source="nav-bar.fxml"/>

</VBox>