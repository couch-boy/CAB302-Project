<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<VBox alignment="TOP_LEFT" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.cab302project.HotspotsController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Button text="Back to Dashboard" onAction="#onBackButtonClick"/>
    <WebView fx:id="mapView" prefHeight="600.0" prefWidth="900.0" />

    <!-- Bottom navigation bar -->
    <fx:include fx:id="navBar" source="nav-bar.fxml"/>
    
</VBox>